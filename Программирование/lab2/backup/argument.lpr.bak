program argument;

uses
  SysUtils;

var
  sum, prod: integer;
  even, odd: integer;
  i: integer;
  num: integer;

begin
  sum := 0;
  prod := 1;
  even := 0;
  odd := 0;

  for i := 1 to ParamCount do
  begin
    sum := sum + ParamStr(i).ToInteger;
    prod := prod * ParamStr(i).ToInteger;

    if num mod 2 = 0 then
       even := even + 1
    else
      odd := odd + 1;

  end;
  WriteLn('Сумма: ', sum);
  WriteLn('Произведение : ', prod);
  WriteLn('Четные : ', even);
  WriteLn('Нечетные : ', odd);
end.

